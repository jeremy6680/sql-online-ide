# Server port (default: 3001)
PORT=3001

# ─── Authentication ───────────────────────────────────────────────────────────
#
# Static users defined at deploy time (backward-compatible).
# Passwords are plaintext here — hashed with bcrypt at server startup.
#
# Simple:   AUTH_USERS=admin:changeme
#           AUTH_USERS=alice:passA,bob:passB
# JSON:     AUTH_USERS=[{"username":"admin","password":"changeme"}]
#
AUTH_USERS=

# Enable self-registration (users can sign up via the UI).
# Registered accounts are stored in data/auth/users.json.
ALLOW_REGISTRATION=false

# Secret used to sign JWT tokens. Use a long random string in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production

# ─── API Key Encryption ───────────────────────────────────────────────────────
#
# Used to encrypt users' stored API keys at rest (AES-256-GCM).
# Required when users store their own Anthropic/OpenAI keys.
# If not set, falls back to JWT_SECRET (not recommended in production).
#
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
ENCRYPTION_KEY=

# ─── Password reset email (SMTP) ─────────────────────────────────────────────
#
# Required for the "Forgot password" feature to send reset links by email.
# Without SMTP, the reset link is printed to the server console instead
# (useful for local/dev setups).
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   ← App Password (myaccount.google.com/apppasswords)
#
# Brevo / Mailgun / Resend also work with their SMTP credentials.
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=    # Sender address, defaults to SMTP_USER if not set

# Base URL of the app — used to build the reset link in emails.
# Example: https://sql-ide.example.com
APP_URL=http://localhost:3001
