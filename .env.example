# Server port (default: 3001)
PORT=3001

# ─── Authentication ──────────────────────────────────────────────────────────
#
# Optional. If not set, the app is accessible to everyone and the
# "Sign in" button is hidden.
#
# List of users in JSON format. Passwords are plaintext here — they are
# hashed with bcrypt at server startup.
#
# Single user:
# AUTH_USERS=[{"username":"admin","password":"changeme"}]
#
# Multiple users:
# AUTH_USERS=[{"username":"alice","password":"passA"},{"username":"bob","password":"passB"}]
#
AUTH_USERS=

# Secret used to sign JWT tokens. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production
